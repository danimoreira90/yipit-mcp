# Copy to .env (gitignored) and fill in. Local dev values shown.
# Postgres (Docker Compose, local dev only — creds approved for local use).
DATABASE_URL=postgresql+asyncpg://kpi:kpi@localhost:5432/kpi
TEST_DATABASE_URL=postgresql+asyncpg://kpi:kpi@localhost:5432/kpi_test

# Only needed to RUN the ergonomics eval (Phase 8). Leave blank otherwise —
# the eval runner skips cleanly when this is unset. Never commit a real key.
ANTHROPIC_API_KEY=
